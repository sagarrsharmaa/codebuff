# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/codebuff?schema=public"

# Auth.js
NEXTAUTH_SECRET="generate-a-random-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Stripe
# Get your keys at https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY="sk_test_..."

# Get this after running: stripe listen --forward-to localhost:3000/api/stripe/webhook
STRIPE_WEBHOOK_SECRET="whsec_..."

# Create products + prices via Stripe CLI, then paste the price IDs here:
#   stripe products create --name="Starter" --description="Starter Plan"
#   stripe products create --name="Pro" --description="Pro Plan"
#   stripe prices create --unit-amount=2900 --currency=usd --recurring='{"interval":"month"}' --product=PROD_ID
#   stripe prices create --unit-amount=27600 --currency=usd --recurring='{"interval":"year"}' --product=PROD_ID
#   stripe prices create --unit-amount=9900 --currency=usd --recurring='{"interval":"month"}' --product=PROD_ID
#   stripe prices create --unit-amount=94800 --currency=usd --recurring='{"interval":"year"}' --product=PROD_ID
STRIPE_PRICE_ID_STARTER_MONTHLY="price_..."
STRIPE_PRICE_ID_STARTER_YEARLY="price_..."
STRIPE_PRICE_ID_PRO_MONTHLY="price_..."
STRIPE_PRICE_ID_PRO_YEARLY="price_..."

# Resend (email)
RESEND_API_KEY="re_..."

# Optional: GitHub OAuth (for Auth.js)
GITHUB_ID=""
GITHUB_SECRET=""

# Auth.js (NextAuth v5)
AUTH_SECRET="generate-a-random-secret-here-use-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Google OAuth (for Auth.js)
# Create credentials at https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
